---
import LayoutWithoutSideBar from "@layouts/LayoutWithoutSideBar.astro"
import { friendLinks } from "@/types/cfg-frlink"
import { getImageUrl } from "@/utils/get-bg-url"
---

<LayoutWithoutSideBar>

<div class="card-base mt-[20px] relative-content max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 transition-all duration-300">
    <!-- 头部内容区域 -->
    <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-slate-800 via-indigo-800 to-purple-800 bg-clip-text text-transparent tracking-tight drop-shadow-sm">
            🔗 友情链接
        </h1>
        <div class="inline-flex items-center gap-2 mt-5 px-5 py-1.5 bg-white/40 backdrop-blur-md rounded-full text-indigo-800 text-sm font-medium border border-white/50 shadow-sm">
            <span>✨</span> 一群非常好的小伙伴们
        </div>
        <p class="text-slate-700 max-w-2xl mx-auto mt-4 text-base font-medium drop-shadow-sm">很高兴与优秀的你们相遇于此，愿我们彼此照亮，在各自的路上走得更远。</p>
    </div>

    <!-- 分组 -->
    <div id="links-group" class="space-y-14">
        {
            friendLinks.map((group) => (
                <div class="group-section">
                    
                    {/* 分组顶部的介绍 */}
                    <div class="border-l-4 border-blue-500/80 pl-5 mb-6">
                        <div class="flex items-center gap-3 flex-wrap">
                            <h2 class="text-2xl md:text-3xl font-bold text-slate-800 flex items-center gap-2 drop-shadow-sm">
                                {group.name}
                            </h2>

                            {
                                group.tag && 
                                <span class="text-xs font-semibold bg-blue-200/70 backdrop-blur-sm text-blue-900 rounded-full px-3 py-1 border border-white/40">
                                    {group["link-list"].length}个{group.tag}
                                </span>
                            }
                        </div>

                        <p class="text-slate-700 text-sm md:text-base mt-2 max-w-3xl bg-white/30 backdrop-blur-sm rounded-xl px-4 py-2 border border-white/20">
                            {group.desc}
                        </p>
                    </div>

                    {/* 分组下的站点列表容器 */}
                    <div class="friendlink-cards-container">
                        {
                            group["link-list"].map((link) => (
                                <div class="friend-card">
                                    <div class="frlink-cover" style=`background-size:cover; background-image: url(${getImageUrl(link.avatar)});`>
                                        <div class="absolute inset-0 bg-black/20"></div>
                                        <div class="frlink-name">{link.name}</div>
                                    </div>
                                    <div class="p-5">
                                        <div class="flex items-start gap-4 pb-2">
                                            {/* 站点图标，取首字母/文字 */}
                                            <div class=`link-icon` style=`background-image: ${link["icon-color"]}; background-color: ${link["icon-color"]};`>{link.name.slice(0,1)}</div>
                                            <div class="flex-1">
                                                <h3 class="text-xl font-bold text-slate-800 hover:text-blue-700 transition">
                                                    <a href=`${link.link}` target="_blank" rel="noopener noreferrer">
                                                        {link.name}
                                                    </a>
                                                </h3>
                                                
                                                {
                                                    /* 站点标题下方的小 tag */
                                                    link.tag && <div class="link-tag">{link.tag}</div>
                                                }
                                                
                                            </div>
                                        </div>
                                        <div class="text-slate-700 text-sm leading-relaxed my-3">
                                            <p>{link.descr}</p>
                                        </div>
                                        <div class="pt-3 mt-auto flex justify-end">
                                            <a href=`${link.link}` target="_blank" rel="noopener noreferrer" class="goto-link">访问网站 
                                                <span class="visit-link-arrow inline-block">→</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            ))
                        }
                    </div>

                </div>
            ))
        }
    </div>

    <!-- 页脚 -->
    <div class="mt-12 pt-6 border-t border-white/40 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-slate-700">
        <div class="bg-white/40 backdrop-blur-md px-4 py-1.5 rounded-full text-slate-800 text-xs md:text-sm border border-white/40 shadow-sm">
            🤝 交换链接 & 建议: <a href="mailto:friends@linkhub.dev" class="font-medium text-blue-700 hover:underline">friends@linkhub.dev</a>
        </div>
        <div class="flex items-center gap-1 bg-white/30 backdrop-blur-sm px-3 py-1 rounded-full">
            <span>🌐</span>
            <span>欢迎您成为本站的一员</span>
        </div>
    </div>
</div>

</LayoutWithoutSideBar>

<style>
    .link-tag {
        @apply border rounded-full px-2 py-1 border-blue-200/60
        w-fit bg-white text-[13px];
        box-shadow: 5px 5px 20px rgba(0,0,0,0.2);
    }

    .goto-link {
        @apply group-card-link inline-flex items-center 
        gap-1 text-sm font-semibold text-blue-700 bg-white/60
        backdrop-blur-sm border border-blue-200/60 rounded-full
        px-4 py-1.5 hover:bg-blue-600 hover:text-white 
        transition-all shadow-sm;
    }

    .frlink-cover {
        @apply h-32 w-full bg-no-repeat bg-center relative 
        flex items-end justify-start;
    }

    .frlink-name {
        @apply relative z-[2] p-3 text-white font-bold 
        text-xl tracking-wide drop-shadow-md;
    }

    .link-icon {
        @apply w-12 h-12 rounded-2xl flex items-center 
        justify-center text-white font-bold text-xl 
        shadow-md flex-shrink-0;
    }


    /* 自定义核心布局 —— 纯CSS自适应宽度 (基于 :has() 选择器，无需JS) */
    /* 卡片容器使用 flex 布局，结合 :has() 动态改变子项宽度 */
    .friendlink-cards-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem; /* gap-6 */
    }

    /* 基础样式：移动端默认每个卡片占满宽度 */
    .friendlink-cards-container .friend-card {
        width: 100%;
        transition: all 0.2s;
    }

    /* 当容器内只有 1 个卡片时：占满整行 */
    .friendlink-cards-container:has(.friend-card:only-child) .friend-card {
        width: 100%;
    }

    /* 当容器内恰好有 2 个卡片时：各占一半宽度 (减去间隙) */
    .friendlink-cards-container:has(.friend-card:nth-child(2):last-child) .friend-card {
        width: calc(50% - 0.75rem);
    }

    /* 当容器内有 3 个或更多卡片时：每个卡片占三分之一宽度 (三列布局) */
    /* 注意：3个卡片时正好一行，4个以上会换行，但每行依然是3列（因为宽度固定为三分之一） */
    .friendlink-cards-container:has(.friend-card:nth-child(3)) .friend-card,
    .friendlink-cards-container:has(.friend-card:nth-child(4)) .friend-card,
    .friendlink-cards-container:has(.friend-card:nth-child(5)) .friend-card,
    .friendlink-cards-container:has(.friend-card:nth-child(6)) .friend-card {
        width: calc(33.333% - 1rem); /* 调整间隙使之精确对齐 */
    }

    /* 对于宽屏，最多保持三列；对于2个卡片的情况上述规则已覆盖 */
    /* 小屏幕（<768px）强制每个卡片占满整行，提升可读性 */
    @media (max-width: 767px) {
        .friendlink-cards-container .friend-card {
            width: 100% !important;
        }
    }

    /* 中等屏幕下确保三列布局宽度合适 */
    @media (min-width: 768px) and (max-width: 1023px) {
        .friendlink-cards-container:has(.friend-card:nth-child(3)) .friend-card,
        .friendlink-cards-container:has(.friend-card:nth-child(4)) .friend-card,
        .friendlink-cards-container:has(.friend-card:nth-child(5)) .friend-card,
        .friendlink-cards-container:has(.friend-card:nth-child(6)) .friend-card {
            width: calc(33.333% - 1rem);
        }
        .friendlink-cards-container:has(.friend-card:nth-child(2):last-child) .friend-card {
            width: calc(50% - 0.75rem);
        }
    }

    /* 卡片交互效果 */
    .friend-card {
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(12px);
        border-radius: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        transition: transform 0.25s ease, box-shadow 0.3s ease, border-color 0.2s;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .friend-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 32px -12px rgba(0, 0, 0, 0.2);
        border-color: rgba(255, 255, 255, 0.6);
    }

    .visit-link-arrow {
        transition: transform 0.2s ease;
    }

    .group-card-link:hover .visit-link-arrow {
        transform: translateX(4px);
    }
</style>
