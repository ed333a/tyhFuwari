---

import { siteConfig } from "@/types/config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
---

<div class="p-[20px] my-[20px] w-fill card-base transition border-dashed border-[oklch(85%_0.01_var(--hue))] dark:border-white/15 rounded-2xl mb-12 flex flex-col items-center justify-center px-6">
    <div class="transition text-50 text-sm text-center">
        &copy; <span id="copyright" class="text-[16px]">{currentYear} {siteConfig.author}.</span>
        <span class="text-[16px]">LICENSE: <a class="transition link text-[var(--primary)] text-[16px] font-medium" target="_blank" href={siteConfig.license.url}>{siteConfig.license.name}</a></span> /
        <a class="transition link text-[var(--primary)] text-[16px] font-medium" target="_blank" href={url('rss.xml')}>RSS</a> /
        <a class="transition link text-[var(--primary)] text-[16px] font-medium" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a><br>
        <span class="text-[16px]">Framework:</span>
        <a class="transition link text-[var(--primary)] text-[16px] font-medium" target="_blank" href="https://astro.build">Astro</a> | 
        <span class="text-[16px]">Template:</span>
        <a class="transition link text-[var(--primary)] text-[16px] font-medium" target="_blank" href="https://github.com/ed333a/tyhFuwari">tyhFuwari</a> |
        <span class="text-[16px]">Forked from:</span>
        <a class="transition link text-[var(--primary)] text-[16px] font-medium" target="_blank" href="https://github.com/saicaca/fuwari">Fuwari</a>
    </div>
</div>